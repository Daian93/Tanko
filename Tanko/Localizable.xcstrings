    "%lld" : {
      "comment" : "A button that, when tapped, toggles the \"owned\" status of a specific volume in a manga. The button displays the volume number and has a green background when the volume is owned, and a default background",
      "isCommentAutoGenerated" : true
    },
    "%lld / %lld leídos" : {
      "comment" : "A text showing the current and total number of volumes a manga is reading. The first argument is the current volume number. The second argument is the total volume number.",
      "isCommentAutoGenerated" : true,
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "%1$lld / %2$lld leídos"
          }
        }
      }
    },
    "%lld de %lld leídos" : {
      "comment" : "A text showing the current reading progress of a manga, formatted as \"X de Y leídos\". The first argument is the number of volumes already read. The second argument is the total number of volumes.",
      "isCommentAutoGenerated" : true,
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "%1$lld de %2$lld leídos"
          }
        }
      }
    },
    "%lld en estantería" : {
